{
  "name": "agentic-wallet-sandbox",
  "version": "1.0.0",
  "private": true,
  "description": "Agentic wallet prototype on Solana devnet",
  "scripts": {
    "dev:api": "pnpm -C apps/api dev",
    "dev:web": "pnpm -C apps/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -C apps/api test",
    "test:unit": "pnpm -C apps/api test:unit",
    "test:integration": "pnpm -C apps/api test:integration",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
