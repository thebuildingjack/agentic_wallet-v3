# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Solana ───────────────────────────────────────────────────────────────────
# Default devnet public RPC (rate limited). Use Helius/QuickNode for reliability.
SOLANA_RPC_URL=https://api.devnet.solana.com

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random string. Required for all write endpoints.
API_KEY=change-me-to-a-secure-random-string

# ─── Encryption ───────────────────────────────────────────────────────────────
# MUST be exactly 32 bytes, base64-encoded.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AGENT_MASTER_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# ─── Receiver wallet ──────────────────────────────────────────────────────────
# A devnet wallet address to receive test transfers. Your Phantom address works fine.
RECEIVER_PUBLIC_KEY=REPLACE_WITH_DEVNET_PUBKEY

# ─── Funder wallet (RECOMMENDED — avoids airdrop 429 rate limits) ─────────────
#
# If set, newly created agents are funded via direct SOL transfer from this
# wallet instead of requestAirdrop(). You funded this wallet manually via faucet.
#
# HOW TO GET YOUR FUNDER_SECRET_KEY:
#
# Option A — From Phantom:
#   Settings → Security & Privacy → Export Private Key
#   Copy the base58 string and paste below.
#
# Option B — Generate a fresh keypair (recommended for separation of concerns):
#   node -e "
#     const {Keypair} = require('@solana/web3.js');
#     const bs58 = require('bs58');
#     const kp = Keypair.generate();
#     console.log('Public key:', kp.publicKey.toBase58());
#     console.log('Secret key (base58):', bs58.default.encode(kp.secretKey));
#   "
#   Then fund it at: https://faucet.solana.com
#
# Option C — From solana-keygen (JSON array format also supported):
#   cat ~/.config/solana/id.json
#   The raw JSON array can be pasted directly — the app handles both formats.
#
# SECURITY: This key is NEVER logged. Only the public key appears in logs.
# For production, use a proper secrets manager instead of an env file.
#
FUNDER_SECRET_KEY=

# ─── Funding thresholds ───────────────────────────────────────────────────────
# Minimum SOL to ensure each new agent has (default: 0.05 SOL)
MIN_AGENT_SOL=0.05
# Minimum SOL an agent must have to execute any action (default: 0.01 SOL)
MIN_ACTION_SOL=0.01

# ─── SPL token ────────────────────────────────────────────────────────────────
SPL_MINT_DECIMALS=6

# ─── Jupiter swap ─────────────────────────────────────────────────────────────
JUPITER_SLIPPAGE_BPS=50
JUPITER_SWAP_AMOUNT_LAMPORTS=10000
JUPITER_INPUT_MINT=So11111111111111111111111111111111111111112
JUPITER_OUTPUT_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ─── Harness ──────────────────────────────────────────────────────────────────
HARNESS_INTERVAL_MS=30000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
